{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://canon.dev/schema/questions.v1.json",
  "title": "Canon eval questions.yaml",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "domain", "questions"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "domain": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "questions": {
      "type": "array",
      "items": { "$ref": "#/$defs/question" },
      "default": []
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stringArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" },
      "uniqueItems": true,
      "default": []
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "question", "expected_metric", "expected_source"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "question": { "$ref": "#/$defs/nonEmptyString" },
        "expected_metric": { "$ref": "#/$defs/nonEmptyString" },
        "expected_source": {
          "type": "string",
          "enum": ["primary", "warehouse"]
        },
        "expected_filters": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "array"]
          },
          "default": {}
        },
        "expected_time_scope": { "$ref": "#/$defs/nonEmptyString" },
        "difficulty": {
          "type": "string",
          "enum": ["easy", "medium", "hard"]
        },
        "notes": { "$ref": "#/$defs/nonEmptyString" }
      }
    }
  }
}

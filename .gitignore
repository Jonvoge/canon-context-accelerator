# Canon cache (machine-owned)
# Allow only the two files the deployed MCP needs; ignore everything else
.canon-cache/**
!.canon-cache/**/.gitignore
!.canon-cache/*/
!.canon-cache/**/schema.json
!.canon-cache/**/profiles.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/

# uv
.python-version

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local

# Testing
.coverage
htmlcov/
.pytest_cache/

# Bootstrap docs (keep folder, ignore large uploads)
bootstrap-docs/**/*.pdf
bootstrap-docs/**/*.docx
bootstrap-docs/**/*.xlsx
!bootstrap-docs/**/README.md

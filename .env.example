# Canon Context Accelerator — environment variables
# Copy to .env and fill in values. Never commit .env to git.

# ─── Fabric / Power BI ────────────────────────────────────────────────────────
CANON_FABRIC_TENANT_ID=
CANON_FABRIC_CLIENT_ID=
CANON_FABRIC_CLIENT_SECRET=

# Workspace containing the semantic model(s)
CANON_FABRIC_WORKSPACE_ID=

# Semantic model — use name OR dataset_id (name is resolved at runtime)
CANON_FABRIC_DATASET_NAME=
CANON_FABRIC_DATASET_ID=

# ─── Fabric SQL endpoint ──────────────────────────────────────────────────────
CANON_SQL_SERVER=
CANON_SQL_DATABASE=

# ─── MCP server ───────────────────────────────────────────────────────────────
CANON_MCP_TRANSPORT=streamable-http    # stdio | streamable-http
CANON_MCP_PORT=8000
CANON_REPO_ROOT=/app

# ─── LLM (optional — bootstrap enrichment + interview) ────────────────────────
ANTHROPIC_API_KEY=

# ─── GitHub (bootstrap PRs + scan issues) ─────────────────────────────────────
CANON_GITHUB_REPO=Jonvoge/canon-context-accelerator
CANON_GITHUB_TOKEN=
